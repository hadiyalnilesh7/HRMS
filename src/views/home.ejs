<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HRMS - Premium Hotel Management Software</title>
    <link rel="icon" type="image/png" href="/image/logo.png">
    
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    
    <!-- Core Stylesheet (Includes landing.css) -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="home-page">

    <!-- Glassmorphic Navbar -->
    <nav class="home-navbar">
        <a href="/" class="home-brand" aria-label="HRMS Home">
            <img src="/image/logo.png" alt="Hotel Management Logo" class="home-brand-logo">
            <span class="home-brand-text">HRMS</span>
        </a>
        <div class="home-nav-actions">
            <a href="/login" class="btn-nav-login">Sign In</a>
            <a href="/register" class="btn-nav-signup">Get Started</a>
        </div>
    </nav>

    <!-- Stunning Hero Section -->
    <section class="hero-section">
        <div class="hero-container">
            <!-- Left Content -->
            <div class="hero-content">
                <h1>
                    Manage Your Hotel with <br />
                    <span class="gradient-text">Absolute Precision.</span>
                </h1>
                <p>
                    Elevate your hospitality business. HRMS is the all-in-one software built to seamlessly handle bookings, streamline housekeeping, and drive your revenue to new heights.
                </p>
                <div class="hero-buttons">
                    <a href="/register" class="btn-primary-lg">
                        Start for Free <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a href="#features" class="btn-secondary-lg">
                        Explore Features
                    </a>
                </div>
            </div>
            
            <!-- Right Mockup Visual -->
            <div class="hero-image-wrapper">
                <div class="hero-image-card">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Beautiful Hotel Dashboard" class="hero-dashboard-mockup" style="aspect-ratio: 16/10; object-fit: cover;">
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section" id="features">
        <div class="section-header">
            <span class="section-subtitle">Powerful Capabilities</span>
            <h2 class="section-title">Everything you need to run a world-class hotel.</h2>
        </div>

        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-indigo">
                    <i class="fa-solid fa-bed"></i>
                </div>
                <h3>Smart Room Management</h3>
                <p>Effortlessly track inventory, set dynamic pricing, and monitor real-time cleaning statuses across all your floors.</p>
            </div>

            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-emerald">
                    <i class="fa-regular fa-calendar-check"></i>
                </div>
                <h3>Frictionless Bookings</h3>
                <p>Handle your guest reservations seamlessly with an intuitive calendar, rapid check-ins, and one-click check-outs.</p>
            </div>

            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-amber">
                    <i class="fa-solid fa-utensils"></i>
                </div>
                <h3>Restaurant & Orders</h3>
                <p>Fully integrated digital POS. Manage your kitchen menu, track room service orders, and add charges directly to guest folios.</p>
            </div>

            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-blue">
                    <i class="fa-solid fa-chart-pie"></i>
                </div>
                <h3>Financial Dashboard</h3>
                <p>Get rich, actionable insights into your daily revenue, occupancy rates, and overall business performance instantly.</p>
            </div>

            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-rose">
                    <i class="fa-solid fa-broom"></i>
                </div>
                <h3>Housekeeping Dispatch</h3>
                <p>Automatically notify your staff when rooms need cleaning upon checkout to ensure zero delays for new arriving guests.</p>
            </div>

            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feature-icon-wrapper icon-purple">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </div>
                <h3>Automated Invoicing</h3>
                <p>Generate beautiful, branded PDF invoices combining room charges and food orders with absolute zero manual math required.</p>
            </div>
        </div>
    </section>

    <!-- Minimal Footer -->
    <footer class="landing-footer">
        <p>&copy; 2026 HRMS Enterprise Software. Empowering hospitality worldwide.</p>
    </footer>

</body>
</html>
