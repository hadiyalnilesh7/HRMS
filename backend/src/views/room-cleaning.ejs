<%- include("./layouts/header") %>
<%- include("./layouts/sidebar") %>

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1"><i class="fa-solid fa-broom text-primary"></i> Room Cleaning</h2>
        <p class="text-muted mb-0">Manage rooms that require housekeeping.</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-12">
        <div class="card">
          <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fa-solid fa-list me-2 text-warning"></i> Rooms Needing Cleaning</h5>
            <span class="badge bg-warning text-dark"><%= roomsNeedingCleaning ? roomsNeedingCleaning.length : 0 %> pending</span>
          </div>

          <div class="card-body p-0">
            <% if (roomsNeedingCleaning && roomsNeedingCleaning.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="ps-4">Room No.</th>
                      <th>Type</th>
                      <th>Status</th>
                      <th class="text-end pe-4">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% roomsNeedingCleaning.forEach(r => { %>
                      <tr>
                        <td class="ps-4 fw-bold text-primary" data-label="Room No"><%= r.roomNo %></td>
                        <td data-label="Type"><span class="badge bg-light text-dark border"><%= r.type %></span></td>
                        <td data-label="Status">
                          <span class="badge bg-warning-subtle text-warning border border-warning"><i class="fa-solid fa-broom me-1"></i> Cleaning Required</span>
                        </td>
                        <td class="text-end pe-4" data-label="Actions">
                          <form method="POST" action="/rooms/markClean/<%= r._id %>" class="d-inline" data-confirm="Mark room <%= r.roomNo %> as clean and available?">
                            <input type="hidden" name="id" value="<%= r._id %>">
                            <button type="submit" class="btn btn-sm btn-success">
                              <i class="fa-solid fa-check me-1"></i> Mark as Clean
                            </button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="text-center py-5 text-muted">
                <i class="fa-solid fa-check-circle fa-4x mb-3 text-success opacity-50"></i>
                <h4 class="fw-bold">All caught up!</h4>
                <p>There are no rooms that currently require cleaning.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
</div>

<%- include("./layouts/footer") %>
