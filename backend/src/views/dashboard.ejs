<%- include("layouts/header") %>
<%- include("layouts/sidebar") %>

<div class="dashboard-main px-0 w-100">
    <div class="welcome-section mb-5 mx-0">
        <div class="welcome-content d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="fw-bold mb-2 h2 text-white">Welcome, <%= (user && user.name) ? user.name : 'Administrator' %>! 👋</h1>
                <p class="mb-0 text-white-50 fs-5">Here is <%= (user && user.hotelName) ? user.hotelName : 'your hotel' %>'s performance at a glance.</p>
            </div>
            <div class="glass-pill text-white">
                <i class="far fa-calendar-alt me-2"></i>
                <span id="current-date" class="fw-medium"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Today's Revenue -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Today's Revenue</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;">₹<%= typeof todayRevenue !== 'undefined' ? todayRevenue.toLocaleString('en-IN') : 0 %></h2>
                    </div>
                    <div class="icon-box bg-indigo-light">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <span class="text-success small fw-bold"><i class="fa-solid fa-arrow-trend-up me-1"></i> Today's Earnings</span>
                </div>
            </div>
        </div>

        <!-- Monthly Revenue -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Monthly Revenue</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;">₹<%= typeof monthRevenue !== 'undefined' ? monthRevenue.toLocaleString('en-IN') : 0 %></h2>
                    </div>
                    <div class="icon-box bg-emerald-light">
                        <i class="fa-solid fa-wallet"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <span class="text-muted small fw-medium">Total earnings this month</span>
                </div>
            </div>
        </div>

        <!-- Active Bookings -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Active Bookings</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;"><%= bookingsCount %></h2>
                    </div>
                    <div class="icon-box bg-blue-light">
                        <i class="fa-solid fa-users"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <span class="text-primary small fw-bold">Current guests staying</span>
                </div>
            </div>
        </div>

        <!-- Available Rooms -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Available Rooms</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;"><%= typeof availableRooms !== 'undefined' ? availableRooms : 0 %> <span class="text-muted fs-5 fw-normal">/ <%= roomsCount %></span></h2>
                    </div>
                    <div class="icon-box bg-emerald-light" style="background: #dcfce7; color: #16a34a;">
                        <i class="fa-solid fa-door-open"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <span class="text-muted small fw-medium">Ready for new check-ins</span>
                </div>
            </div>
        </div>

        <!-- Pending Orders -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Pending Orders</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;"><%= pendingOrdersCount %></h2>
                    </div>
                    <div class="icon-box bg-amber-light">
                        <i class="fa-solid fa-utensils"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <span class="text-warning small fw-bold" style="color: #d97706 !important;"><i class="fa-solid fa-clock me-1"></i> Needs kitchen attention</span>
                </div>
            </div>
        </div>

        <!-- Rooms Needing Cleaning (Metric) -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="metric-card" <% if (roomsNeedingCleaning && roomsNeedingCleaning.length > 0) { %>style="border-color: #fca5a5; background: #fff1f2;"<% } %>>
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-secondary fw-bold mb-1 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Needs Cleaning</p>
                        <h2 class="fw-bold mb-0 text-dark" style="font-size: 2.25rem;"><%= roomsNeedingCleaning ? roomsNeedingCleaning.length : 0 %></h2>
                    </div>
                    <div class="icon-box bg-rose-light">
                        <i class="fa-solid fa-broom"></i>
                    </div>
                </div>
                <div class="mt-auto pt-3 border-top" style="border-color: #f1f5f9 !important;">
                    <% if (roomsNeedingCleaning && roomsNeedingCleaning.length > 0) { %>
                        <span class="text-danger small fw-bold"><i class="fa-solid fa-circle-exclamation me-1"></i> Housekeeping required!</span>
                    <% } else { %>
                        <span class="text-success small fw-bold"><i class="fa-solid fa-check me-1"></i> All rooms clean</span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Section -->
    <div class="row g-4 mb-5">
        <!-- Quick Links -->
        <div class="col-12">
            <div class="bg-white rounded-4 p-4 border shadow-sm" style="border-color: #e2e8f0; border-radius: 20px;">
                <h5 class="section-title mb-4"><i class="fa-solid fa-bolt" style="color: #f59e0b;"></i> Quick Links</h5>
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <a href="/booking" class="quick-action-card">
                            <i class="fa-solid fa-plus-circle quick-action-icon d-block"></i>
                            <span class="fw-bold fs-6">New Book</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/order" class="quick-action-card">
                            <i class="fa-solid fa-utensils quick-action-icon d-block" style="color: #d97706;"></i>
                            <span class="fw-bold fs-6">New Order</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/rooms" class="quick-action-card">
                            <i class="fa-solid fa-door-open quick-action-icon d-block" style="color: #10b981;"></i>
                            <span class="fw-bold fs-6">Manage Rooms</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/menu" class="quick-action-card">
                            <i class="fa-solid fa-clipboard-list quick-action-icon d-block" style="color: #e11d48;"></i>
                            <span class="fw-bold fs-6">Menu Items</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("layouts/footer") %>
